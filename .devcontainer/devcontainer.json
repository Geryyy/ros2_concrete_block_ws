{
  "name": "ROS2 Baustelle WS Humble",
  // "image": "gitlab-intern.ait.ac.at:5010/vac-cds/projects/2019_lp_autonome_baustelle_grp/ros2_baustelle_ws:master",
  "dockerFile": "Dockerfile.vscode",
  "build": {
    "context": ".."
  },
  // "build": { //docker build arguments
  //   "args": {
  //     //the from argument (docker we start with)
  //     //  if you do not have an nvidia driver (eg intel)
  //     // "from": "ubuntu:jammy"
  //     //  if you have an nvidia driver use the following
  //     //"from": "nvidia/cudagl:11.1.1-devel-ubuntu20.04"
  //   }
  // },
  // "context": "..",
  //"dockerComposeFile": ["docker-compose.yml", "docker-compose.extend.yml"],
  //"service": "vscode_service",
  //"workspaceMount": "source=${localWorkspaceFolder}/src,target=/workspace,type=bind,consistency=delegated",
  //"workspaceFolder": "/workspace"
  //"shutdownAction": "stopCompose",
  //"runServices" : ["vscode_service"],
  // Set *default* container specific settings.json values on container create.
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.shell.linux": "/bin/bash",
        "workbench.colorTheme": "Monokai Dimmed"
      },
      // Add the IDs of extensions you want installed when the container is created.
      "extensions": [
        "anthropic.claude-code",
        "charliermarsh.ruff",
        "dotjoshjohnson.xml",
        "eamodio.gitlens",
        "foxundermoon.shell-format",
        "github.copilot-chat",
        "github.copilot",
        "mhutchie.git-graph",
        "ms-azuretools.vscode-docker",
        "ms-iot.vscode-ros",
        "ms-python.python",
        "ms-vscode.cmake-tools",
        "ms-vscode.cpptools-extension-pack",
        "openai.chatgpt",
        "pascalreitermann93.vscode-yaml-sort",
        "redhat.vscode-xml",
        "redhat.vscode-yaml",
        "smilerobotics.urdf",
        "streetsidesoftware.code-spell-checker",
        "yzhang.markdown-all-in-one",
        "zachflower.uncrustify"
      ]
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": "false",
      "username": "vscode",
      "userUid": "1000",
      "userGid": "1000",
      "upgradePackages": "true"
    }
  },
  // Use 'forwardPorts' to make a list of ports inside the container available locally.
  // "forwardPorts": [],
  // Use 'postCreateCommand' to run commands after the container is created.
  // "postCreateCommand": "uname -a",
  // Uncomment to use the Docker CLI from inside the container. See https://aka.ms/vscode-remote/samples/docker-in-docker.
  // "mounts": [ "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind" ],
  // https://docs.docker.com/engine/reference/commandline/run/
  // Uncomment when using a ptrace-based debugger like C++, Go, and Rust
  //"runArgs": [ "--cap-add=SYS_PTRACE", "--security-opt", "seccomp=unconfined", "--runtime", "nvidia", "--privileged", "--gpus", "all", "-e", "DISPLAY", "-e", "QT_X11_NO_MITSHM=1", "--net", "host", "-v", "/home/user/.Xauthority:/root/.Xauthority:rw", "-v", "/tmp/.X11-unix:/tmp/.X11-unix" ],
  "runArgs": [
    // nvidia begin
    "--runtime",
    "nvidia",
    "--gpus",
    "all",
    // nvidia end
    "--cap-add=SYS_PTRACE",
    "--security-opt",
    "seccomp=unconfined",
    "--privileged",
    "-e",
    "DISPLAY=${env:DISPLAY}",
    "-e",
    "QT_X11_NO_MITSHM=1",
    // "-e",
    // "XDG_RUNTIME_DIR=${env:XDG_RUNTIME_DIR}",
    "--net",
    "host",
    //"-v", ".:/workspace:cached",
    // "-v",
    // "/home/user/.Xauthority:/root/.Xauthority:rw",
    // "-v",
    // "/home/murschitzm/test:/mnt/data",
    "-v",
    "/tmp/.X11-unix:/tmp/.X11-unix",
    "--device=/dev:/dev",
    "-v",
    "/opt/ait/install/config:/opt/ait/install/config:ro",
  ],
  "remoteEnv": {
    "FASTRTPS_DEFAULT_PROFILES_FILE": "${localEnv:FASTRTPS_DEFAULT_PROFILES_FILE}",
    "CYCLONEDDS_URI": "${localEnv:CYCLONEDDS_URI}",
    "RMW_IMPLEMENTATION": "${localEnv:RMW_IMPLEMENTATION}"
  },
  // Use 'initializeCommand' to run commands before the container is created.
  // https://github.com/microsoft/vscode-remote-release/issues/7104#issuecomment-1947893195
  // "initializeCommand": "./.devcontainer/initializeCommand.sh",
  // sets correct permission for shell scripts. may be run once only
  "onCreateCommand": "sudo chmod +x .devcontainer/*.sh",
  // needed if using windows -> overrides DISPLAY env for WSL2 docker container. works with linux, too
  // has to be commented out on a LINUX host or we set the display variable according to the host system
  "updateContentCommand": "./.devcontainer/updateContentCommand.sh",
  // this installs the development dependencies
  "postCreateCommand": "./.devcontainer/postCreateCommand.sh",
  // for git settings
  "postAttachCommand": "./.devcontainer/postAttachCommand.sh",
  // Uncomment to connect as a non-root user. See https://aka.ms/vscode-remote/containers/non-root.
  "remoteUser": "vscode"
}
