# ARG from=gitlab-intern.ait.ac.at:5010/vac-cds/projects/2019_lp_autonome_baustelle_grp/ros2_hmi_ws:main
ARG from=osrf/ros:humble-desktop-full
FROM ${from}

ARG CMAKE_INSTALL_PREFIX=/usr/local
ARG NUM_THREADS=8

ENV DEBIAN_FRONTEND=noninteractive
ENV ROS_DISTRO=humble
ENV ACADOS_SOURCE_DIR=/opt/acados
ENV LD_LIBRARY_PATH=/opt/acados/lib
ENV USERNAME=vscode
ENV DOCKER_IMAGE_NAME=ros2_concrete_block_ws

SHELL ["/bin/bash", "-c"]

# Base dependencies
RUN set -exo pipefail && \
  apt-get update -y -qq && \
  apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    git \
    wget \
    curl \
    ca-certificates \
    python3-pip \
    python3-dev \
    python3-setuptools \
    python3-wheel \
    python3-colcon-common-extensions \
    python3-vcstool \
    python3-rosdep \
    python3-pandas \
    ccache \
    clang \
    lld \
    gdb \
    gdbserver \
    libclang-14-dev \
    llvm-dev \
    llvm \
    swig \
    libtool \
    libgoogle-glog-dev \
    libgflags-dev \
    libeigen3-dev \
    coinor-libipopt-dev \
    qttools5-dev-tools \
    python3-pyqt5 \
    ros-humble-angles \
    ros-humble-gazebo-ros-pkgs \
    ros-humble-moveit-core \
    ros-humble-rviz-imu-plugin \
    ros-humble-tf-transformations \
    ros-humble-nav2-behavior-tree \
    ros-humble-nav2-lifecycle-manager \
    ros-humble-octomap-server \
    ros-humble-vision-msgs \
    ros-humble-foxglove-bridge \
    ros-humble-cloudini-ros \
    ros-humble-rmw-cyclonedds-cpp \
    ros-humble-rosbag2-storage-mcap && \
  rosdep init || true && \
  rosdep update --rosdistro="${ROS_DISTRO}" && \
  apt-get clean -y && \
  rm -rf /var/lib/apt/lists/*

WORKDIR /opt

