# Python geometry/runtime dependencies used by the concrete block stack
RUN set -exo pipefail && \
  pip3 install --no-cache-dir \
    python-fcl \
    trimesh

# Install PyTorch (CUDA 12.8 wheels, Blackwell/sm_120 support) and SAM 2.1.
# The RTX 50-series (Blackwell) needs cu128 + torch>=2.7; torch 2.5.x has no
# sm_120 kernels and fails at runtime. SAM2_BUILD_CUDA=0 skips SAM 2's optional
# custom CUDA kernel (only used for some video post-processing) so we do not need
# the full CUDA toolkit/nvcc in the image.
ENV SAM2_CHECKPOINT_DIR=/opt/sam2/checkpoints
# PyTorch's pip index now links to download-r2.pytorch.org (Cloudflare R2)
# whose TLS rejects OpenSSL 3.0.2 in Ubuntu 22.04. Curl via CloudFront works.
# Original pip install (restore when R2 TLS / base image OpenSSL is fixed):
#   pip3 install --no-cache-dir --index-url https://download.pytorch.org/whl/cu128 \
#     torch torchvision && \
ARG TORCH_WHL=torch-2.11.0%2Bcu128-cp310-cp310-manylinux_2_28_x86_64.whl
ARG TORCHVISION_WHL=torchvision-0.26.0%2Bcu128-cp310-cp310-manylinux_2_28_x86_64.whl
RUN set -exo pipefail && \
  mkdir -p /tmp/pytorch_wheels && \
  curl -fSL -o "/tmp/pytorch_wheels/${TORCH_WHL}" \
    "https://download.pytorch.org/whl/cu128/${TORCH_WHL}" && \
  curl -fSL -o "/tmp/pytorch_wheels/${TORCHVISION_WHL}" \
    "https://download.pytorch.org/whl/cu128/${TORCHVISION_WHL}" && \
  pip3 install --no-cache-dir "/tmp/pytorch_wheels/${TORCH_WHL}" "/tmp/pytorch_wheels/${TORCHVISION_WHL}" && \
  rm -rf /tmp/pytorch_wheels && \
  SAM2_BUILD_CUDA=0 pip3 install --no-cache-dir \
    "git+https://github.com/facebookresearch/sam2.git" && \
  mkdir -p "${SAM2_CHECKPOINT_DIR}" && \
  wget -q -O "${SAM2_CHECKPOINT_DIR}/sam2.1_hiera_base_plus.pt" \
    https://dl.fbaipublicfiles.com/segment_anything_2/092824/sam2.1_hiera_base_plus.pt

# Install Open3D v0.18.0 from source
RUN set -exo pipefail && \
  git clone --depth 1 --branch v0.18.0 https://github.com/isl-org/Open3D.git /opt/open3d_src && \
  cd /opt/open3d_src && \
  util/install_deps_ubuntu.sh assume-yes && \
  mkdir -p build && \
  cd build && \
  cmake .. \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX="${CMAKE_INSTALL_PREFIX}" \
    -DBUILD_PYTHON_MODULE=ON \
    -DPYTHON_EXECUTABLE="$(which python3)" \
    -DBUILD_EXAMPLES=OFF \
    -DBUILD_UNIT_TESTS=OFF && \
  make -j"${NUM_THREADS}" && \
  make install && \
  make install-pip-package && \
  ldconfig && \
  rm -rf /opt/open3d_src

